# ============================================================
# Tribes.app Caddyfile — Production Reverse Proxy
# ============================================================
# Caddy auto-provisions Let's Encrypt TLS for all domains.
# Replace {$DOMAIN} with your actual domain or hardcode below.
#
# Usage:
#   DOMAIN=tribes.app docker compose -f docker-compose.prod.yml up -d
# ============================================================

# Shared security headers — imported by every server block
(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Permitted-Cross-Domain-Policies "none"
    }
}

{$APP_DOMAIN:tribes.app} {
    # Next.js app — blue/green load balancing
    # Caddy routes to whichever container is healthy; during deploys
    # both may run briefly, but lb_policy=first prefers the first healthy one.
    reverse_proxy app-blue:9002 app-green:9002 {
        lb_policy first

        # Passive health: mark upstream down after 2 failures
        fail_duration 10s
        max_fails 2

        # Active health: probe /api/health on each upstream every 5s
        health_uri /api/health
        health_interval 5s
        health_timeout 3s
    }

    import security_headers

    # App-specific headers (complement Next.js CSP headers)
    header {
        X-Robots-Tag "noindex, nofollow"  # Remove for public launch
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

{$WS_DOMAIN:ws.tribes.app} {
    # WebSocket relay — must preserve upgrade headers
    reverse_proxy ws-relay:9003 {
        header_up Connection "Upgrade"
        header_up Upgrade "websocket"
    }

    import security_headers
}

{$MEDIA_DOMAIN:media.tribes.app} {
    # SeaweedFS Filer — public media CDN
    # S3-uploaded objects are stored under /buckets/<bucket>/<key> in the Filer,
    # but public URLs use /<bucket>/<key>. Rewrite to add the /buckets prefix.
    rewrite * /buckets{path}

    reverse_proxy seaweedfs-filer:8888

    import security_headers

    # Long-lived cache for immutable media files
    header Cache-Control "public, max-age=31536000, immutable"

    # Serve from cache when upstream is slow
    header Vary "Accept-Encoding"
}
