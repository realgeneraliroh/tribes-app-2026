<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for Tribes (DEBUG OVERLAY)
  - Block ALL cleartext (HTTP) traffic by default
  - Enforce TLS for tribes.app and subdomains
  - Allow cleartext to local IPs for Capacitor live-reload (debug builds only)
  
  This file overrides src/main/res/xml/network_security_config.xml for debug builds.
  The release config has NO cleartext exceptions.
-->
<network-security-config>
    <!-- Global default: no cleartext allowed -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Tribes domain — TLS only, system trust -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">tribes.app</domain>
    </domain-config>

    <!-- Debug overrides for user-installed CAs -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>

    <!-- Allow cleartext to local network IPs for Capacitor live-reload (debug only) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <!-- Add your LAN IP here for live-reload -->
        <domain includeSubdomains="false">192.168.15.129</domain>
    </domain-config>
</network-security-config>
